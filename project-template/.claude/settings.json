{
  "enabledMcpjsonServers": ["fusebase-dashboards", "fusebase-gate"],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-lint-on-stop.sh",
            "statusMessage": "Running lint before allowing completion…",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-typecheck-on-stop.sh",
            "statusMessage": "Running typecheck before allowing completion…",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/quality-check-features.js",
            "statusMessage": "Quality assesment of the feature…",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
